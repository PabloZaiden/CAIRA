# CAIRA Deployment Strategy: TypeScript + Openai Agent Sdk
#
# Copy this file to .env and fill in your Azure values.
# Authentication uses DefaultAzureCredential via the az credential sidecar.
# Run the following first to set up the azurecli Docker volume:
#   docker volume create azurecli
#   docker run -it --rm -v azurecli:/root/.azure mcr.microsoft.com/azure-cli az login --use-device-code

# ─── Required ────────────────────────────────────────────────────────────

# Azure OpenAI endpoint (e.g., https://<resource>.openai.azure.com)
AZURE_OPENAI_ENDPOINT=

# ─── Optional ────────────────────────────────────────────────────────────

# API version (default: 2025-03-01-preview)
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Model deployment name (default: gpt-5.2-chat)
AGENT_MODEL=gpt-5.2-chat

# Agent display name
AGENT_NAME=

# System prompt for captain agent
CAPTAIN_INSTRUCTIONS=

# System prompt for shanty battle specialist
SHANTY_INSTRUCTIONS=

# System prompt for treasure hunt specialist
TREASURE_INSTRUCTIONS=

# System prompt for crew interview specialist
CREW_INSTRUCTIONS=

# Log level: trace, debug, info, warn, error, fatal (default: debug)
LOG_LEVEL=debug
