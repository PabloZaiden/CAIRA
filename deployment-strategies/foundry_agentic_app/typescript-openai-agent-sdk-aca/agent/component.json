{
  "name": "agent",
  "type": "agent",
  "variant": "openai-agent-sdk",
  "language": "typescript",
  "description": "Agent container using OpenAI Agent SDK (Responses API)",
  "port": 3000,
  "healthEndpoint": "/health",
  "requiredEnv": ["AZURE_OPENAI_ENDPOINT"],
  "optionalEnv": [
    "PORT",
    "HOST",
    "AZURE_OPENAI_API_VERSION",
    "AGENT_MODEL",
    "AGENT_NAME",
    "SHARED_INSTRUCTIONS",
    "DISCOVERY_INSTRUCTIONS",
    "PLANNING_INSTRUCTIONS",
    "STAFFING_INSTRUCTIONS",
    "INBOUND_AUTH_TENANT_ID",
    "INBOUND_AUTH_ALLOWED_AUDIENCES",
    "INBOUND_AUTH_ALLOWED_CALLER_APP_IDS",
    "INBOUND_AUTH_AUTHORITY_HOST",
    "APPLICATIONINSIGHTS_CONNECTION_STRING",
    "LOG_LEVEL",
    "SKIP_AUTH"
  ],
  "contractSpec": "contracts/agent-api.openapi.yaml"
}
