{
  "name": "caira-agent-openai",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "CAIRA Agent container — OpenAI Agent SDK (Responses API) variant",
  "scripts": {
    "start": "node src/server.ts",
    "dev": "node --watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.15.1",
    "@azure/identity": "^4",
    "@openai/agents": "^0.4",
    "@opentelemetry/api": "^1.9.0",
    "fastify": "^5",
    "jose": "^6.1.0",
    "openai": "^6.20",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.9.3",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
