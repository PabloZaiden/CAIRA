    "CAPTAIN_INSTRUCTIONS",
    "TRIAGE_INSTRUCTIONS",
    "SHANTY_INSTRUCTIONS",
    "TREASURE_INSTRUCTIONS",
    "CREW_INSTRUCTIONS",
    "APPLICATIONINSIGHTS_CONNECTION_STRING",
    "LOG_LEVEL",
    "SKIP_AUTH"
