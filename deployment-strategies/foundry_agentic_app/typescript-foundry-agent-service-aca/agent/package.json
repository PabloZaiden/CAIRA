{
  "name": "caira-agent-foundry",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "CAIRA Agent container — Azure AI Foundry (AI Projects v2 SDK) variant",
  "scripts": {
    "start": "node src/server.ts",
    "dev": "node --watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.1.1",
    "@azure/identity": "^4",
    "@microsoft/opentelemetry": "^1.0.2",
    "@opentelemetry/api": "^1.9.1",
    "fastify": "^5",
    "jose": "^6.2.3",
    "openai": "^6.37"
  },
  "overrides": {
    "@opentelemetry/sdk-node": "0.218.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.9.3",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
