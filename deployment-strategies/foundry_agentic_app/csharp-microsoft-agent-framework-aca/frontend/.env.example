# Base URL for the BFF proxy target (server-side env)
API_BASE_URL=http://api:4000

# Entra scope used by the BFF when calling the API (server-side env)
# API_TOKEN_SCOPE=api://<api-app-id>/.default

# Local mock/dev mode only: skip BFF -> API bearer token acquisition
# SKIP_AUTH=true

# API base URL (default: /api, proxied by Vite dev server or nginx)
VITE_API_BASE_URL=/api

# Use SSE streaming for chat messages (default: true, set to "false" to use JSON)
# VITE_USE_STREAMING=true
