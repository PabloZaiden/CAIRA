{
  "name": "caira-strategy-builder",
  "private": true,
  "description": "Repo-level tooling for the CAIRA strategy builder and generated deployment strategies",
  "scripts": {
    "generate": "node scripts/generate-strategies.ts",
    "dev": "node scripts/dev-compose.ts --strategy",
    "dev:azure": "node scripts/dev-azure.ts --strategy",
    "test:compose": "node scripts/compose-test-runner.ts --strategy",
    "test:compose:azure": "node scripts/test-compose-azure.ts --strategy",
    "deploy": "node scripts/deploy-reference-architecture.ts",
    "deploy:destroy": "node scripts/deploy-reference-architecture.ts --destroy",
    "deploy:strategy": "node scripts/deploy-strategy-azure.ts --strategy",
    "deploy:strategy:destroy": "node scripts/deploy-strategy-azure.ts --destroy --strategy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --config ../.github/linters/.prettierrc.yml --ignore-path ../.prettierignore --check \"./**/*.{js,cjs,mjs,ts,tsx,jsx}\" \"../deployment-strategies/**/*.{js,cjs,mjs,ts,tsx,jsx}\"",
    "format:fix": "prettier --config ../.github/linters/.prettierrc.yml --ignore-path ../.prettierignore --write \"./**/*.{js,cjs,mjs,ts,tsx,jsx}\" \"../deployment-strategies/**/*.{js,cjs,mjs,ts,tsx,jsx}\"",
    "verify:env": "./scripts/verify-environment.sh",
    "validate": "node scripts/validate-strategies.ts",
    "test:deployed": "node scripts/test-deployed-strategy.ts --strategy",
    "test:full": "node scripts/test-all.ts",
    "test:full:azure": "node scripts/test-all.ts --include-azure"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "prettier": "^3",
    "typescript": "~5.8",
    "typescript-eslint": "^8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
