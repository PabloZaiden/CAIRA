{
  "name": "caira-reference-frontend-react",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Minimal React frontend reference with a small Node BFF that proxies to the CAIRA API.",
  "scripts": {
    "start": "node src/server.ts",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.3.0",
    "@fastify/static": "^9.1.0",
    "fastify": "^5.8.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
