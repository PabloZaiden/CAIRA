{
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.associations": {
    "**/.github/workflows/*.y*ml": "yaml",
    "CODEOWNERS": "ignore"
  },
  "editor.inlineSuggest.enabled": true,
  "editor.detectIndentation": true,
  "editor.formatOnSave": true,
  "git.autorefresh": true,
  "git.autofetch": true,
  "git.fetchOnPull": true,
  "git.pruneOnFetch": true,
  "git.pullBeforeCheckout": true,
  "git.branchProtection": ["main"],
  "git.mergeEditor": true,
  "git.enableSmartCommit": true,
  "github.branchProtection": true,
  "githubPullRequests.showPullRequestNumberInTree": true,
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.format.singleQuote": false,
  "yaml.schemaStore.enable": true,
  "[terraform]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[terraform-test]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "[hcl]": {
    "editor.defaultFormatter": "hashicorp.terraform"
  },
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "text": "Generate commit messages using the Conventional Commits format: <type>(<scope>): <description>."
    },
    {
      "text": "Use one of these types when applicable: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert."
    },
    {
      "text": "Use the imperative mood, keep the subject concise, and include a scope when it helps explain the change."
    }
  ],
  "git.ignoreLimitWarning": true
}
